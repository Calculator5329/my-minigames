    "outputs": [{ "label": "S1" }, { "label": "S0" }]
  },
  "truthTable": [
    { "in": [0, 0, 0, 0], "out": [0, 0] },
    { "in": [1, 0, 0, 0], "out": [0, 0] },
    { "in": [0, 1, 0, 0], "out": [0, 1] },
    { "in": [1, 1, 0, 0], "out": [0, 1] },
    { "in": [0, 0, 1, 0], "out": [1, 0] },
    { "in": [1, 1, 1, 0], "out": [1, 0] },
    { "in": [0, 0, 0, 1], "out": [1, 1] },
    { "in": [1, 1, 1, 1], "out": [1, 1] }
  ],
  "parGates": 6,
  "hints": [
    "S1 = A2 OR A3.",
    "S0 = A3 OR (A1 AND NOT A2 AND NOT A3)."
